public class ConcentricNumberPattern {
    public static void main(String[] args) {
        int n = 4; // The outermost number
        int size = 2 * n - 1; // Total size of the square

        for (int i = 0; i < size; i++) {
            for (int j = 0; j < size; j++) {
                // Calculate the minimum distance to the borders
                int top = i;
                int left = j;
                int bottom = size - 1 - i;
                int right = size - 1 - j;

                // The number to print is n minus the minimum distance
                int num = n - Math.min(Math.min(top, bottom), Math.min(left, right));

                System.out.print(num + " ");
            }
            System.out.println();
        }
    }
}
